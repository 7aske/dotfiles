{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "./hooks/update-agent-working.sh"
      }
    ],
    "preToolUse": [
      {
        "command": "./hooks/notify-decision.sh",
        "matcher": "AskQuestion|AskUserQuestion"
      }
    ],
    "stop": [
      {
        "command": "./hooks/notify-agent-done.sh"
      }
    ]
  }
}
